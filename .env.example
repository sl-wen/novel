# ── 小说聚合搜索 ──
FASTAPI_DEBUG=True

# ── 支付宝支付 ──────────────────────────────────────
ENABLE_PAYMENT=true

ALIPAY_APP_ID=你的AppID
ALIPAY_APP_PRIVATE_KEY=你的应用RSA2私钥（一长串，包含BEGIN/END）
ALIPAY_PUBLIC_KEY=支付宝RSA2公钥（一长串，包含BEGIN/END）

# 正式环境网关（默认）
ALIPAY_SERVER_URL=https://openapi.alipay.com/gateway.do
ALIPAY_SANDBOX=false

# 回调地址（必须 HTTPS）
ALIPAY_NOTIFY_URL=https://slwen.cn/api/payment/callback
ALIPAY_RETURN_URL=https://slwen.cn/api/payment/return

# 价格（元）
PRICE_SEARCH=0.01
PRICE_DOWNLOAD=0.01
